LOG_LEVEL=INFO
LOG_FILE_PATH=
PPE_URL=http://ppe-detection:8000
FALL_URL=http://fall-detection:8000
EVENT_BUFFER=200
TELEMETRY_MAX_CLOCK_SKEW_SECONDS=30

# Event bus backend: "memory" (default, single-instance, zero extra infra)
# or "redis" (shared across instances; requires REDIS_URL to point at a
# real server — none is provisioned in docker-compose.yml/k8s by default).
EVENT_BUS_BACKEND=memory
REDIS_URL=redis://redis:6379/0

# Event store backend: "memory" (default, lost on restart) or "sqlite"
# (durable across restarts; SQLITE_PATH must point at a writable path).
EVENT_STORE_BACKEND=memory
SQLITE_PATH=./data/events.db
