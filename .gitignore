# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Dataset
archive*/
*.zip
logs/

# EDA output (generated locally, not for production)
ai_ml/fall_detection/eda_plots/
ai_ml/fall_detection/training_plots/
# model binaries are large and built locally — directory is tracked so Docker COPY succeeds
ai_ml/fall_detection/models/*.onnx
ai_ml/fall_detection/models/*.pt
ai_ml/fall_detection/models/*.npz

# Node (root-level safety; app/ has its own ignore too)
node_modules/

.env
.env.*
!**/example.env

# Kubernetes: local filled-in secret copies
k8s/*.local.yaml

# Mosquitto dev credentials — generated locally, never committed
gateway/mosquitto/passwd

# Tooling caches
.ruff_cache/
.pytest_cache/

# OS / editor noise
.DS_Store
